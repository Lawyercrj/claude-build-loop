# ─────────────────────────────────────────────────────────────
# Agent Build Loop — environment template
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and holds your real secrets — never commit it.
# ─────────────────────────────────────────────────────────────

# REQUIRED. Your Anthropic API key. Used by both the executor and reviewer agents.
# Get one at https://console.anthropic.com/ — format: sk-ant-...
ANTHROPIC_API_KEY=

# REQUIRED. Absolute path to the repository the build loop drives. The loop only
# ever writes here — never to its own folder. Format: /absolute/path/to/your-repo
TARGET_REPO=

# OPTIONAL. Telegram approval on your phone. Leave BOTH blank to use terminal
# approval instead. Get the token from @BotFather (/newbot). Format: digits:letters
TELEGRAM_BOT_TOKEN=

# OPTIONAL. Your personal Telegram chat ID — the loop only obeys taps from this ID.
# Find it via https://api.telegram.org/bot<TOKEN>/getUpdates (the "id" under "from").
# Format: a number.
TELEGRAM_CHAT_ID=

# OPTIONAL. Override the reviewer model. Defaults: Claude Opus for a deep review,
# Claude Sonnet for a light one. Format: a model string, e.g. claude-opus-4-8
REVIEWER_MODEL=

# OPTIONAL. Where to write the append-only audit log. Default: logs/audit.log
# (relative to where you run the loop). Format: a file path.
AUDIT_LOG_PATH=

# NOTE: the plan file is NOT an environment variable. Pass it on the command line:
#   npm run dev -- docs/plans/smoke-test.md
